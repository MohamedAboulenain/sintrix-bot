# ── NotebookLM ──────────────────────────────────────────────────────────────
# Copy the notebook ID from your NotebookLM URL:
# https://notebooklm.google.com/notebook/XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
NOTEBOOKLM_NOTEBOOK_ID=

# Max NotebookLM queries per day (resets at midnight UTC)
NLM_DAILY_QUOTA=50

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:8000,http://localhost:5500,https://sintrix.io

LOG_LEVEL=INFO
